# Copia este archivo como referencia para configurar variables de entorno.
# En desarrollo NO es obligatorio: el proyecto arranca con valores por defecto.

# --- Django ---
# Generar una clave nueva: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=cambia-esta-clave-en-produccion
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# DJANGO_CSRF_TRUSTED_ORIGINS=https://midominio.com

# --- Redis / Channels ---
# Poner en false para desarrollar sin Redis (WebSockets en memoria, 1 solo proceso)
DJANGO_USE_REDIS=true
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# --- Celery ---
# CELERY_BROKER_URL=redis://127.0.0.1:6379/0
